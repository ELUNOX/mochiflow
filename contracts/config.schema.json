{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mochiflow.dev/schemas/config.schema.json",
  "title": "MochiFlow config.toml",
  "description": "Project-owned configuration. All project paths are relative to repo root.",
  "$defs": {
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![\\\\/])(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$",
      "description": "Non-empty repository-relative path without parent traversal. Runtime validation additionally resolves symlinks."
    }
  },
  "type": "object",
  "required": ["schema_version", "install_dir", "specs_dir", "index", "constitution", "context", "adr"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "engine_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Deprecated legacy field accepted for old configs; installed engine/VERSION is authoritative."
    },
    "language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
      "description": "Deprecated legacy artifact language. Use [i18n].artifact_language instead."
    },
    "i18n": {
      "type": "object",
      "required": ["artifact_language", "conversation_language"],
      "properties": {
        "artifact_language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
          "not": { "const": "auto" }
        },
        "conversation_language": {
          "type": "string",
          "anyOf": [
            { "const": "auto" },
            { "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$" }
          ]
        }
      }
    },
    "install_dir": { "$ref": "#/$defs/repoPath" },
    "specs_dir": { "$ref": "#/$defs/repoPath" },
    "index": { "$ref": "#/$defs/repoPath" },
    "constitution": {
      "type": "object",
      "description": "Always-loaded user-authored project and local rules.",
      "required": ["project", "local"],
      "properties": {
        "project": { "$ref": "#/$defs/repoPath" },
        "local": { "$ref": "#/$defs/repoPath" }
      }
    },
    "context": {
      "type": "object",
      "description": "Foundational living-spec layer (refresh targets, always-loaded).",
      "required": ["product", "structure", "tech"],
      "properties": {
        "product": { "$ref": "#/$defs/repoPath" },
        "structure": { "$ref": "#/$defs/repoPath" },
        "tech": { "$ref": "#/$defs/repoPath" }
      }
    },
    "adr": {
      "type": "object",
      "description": "Decision and pitfall record stores. `decisions` and `pitfalls` are directory roots, each holding one immutable record per entry plus a generated, gitignored INDEX.md. The JSON schema only constrains presence and non-empty strings; the file-vs-directory rejection is runtime config validation in config.rs.",
      "required": ["decisions", "pitfalls"],
      "properties": {
        "decisions": { "$ref": "#/$defs/repoPath", "description": "Directory root for decision records." },
        "pitfalls": { "$ref": "#/$defs/repoPath", "description": "Directory root for pitfall records." }
      }
    },
    "git": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "base_branch": { "type": "string" },
        "pr_command": { "type": "string" },
        "pr_driver": { "type": "string" }
      }
    },
    "adapter": {
      "type": "object",
      "anyOf": [
        { "required": ["tool"] },
        { "required": ["tools"] }
      ],
      "properties": {
        "tool": { "type": "string", "enum": ["kiro", "agents", "copilot", "claude-code"] },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["kiro", "agents", "copilot", "claude-code"] }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "verify"],
        "properties": {
          "description": { "type": "string" },
          "verify": {
            "type": "object",
            "required": ["default"],
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
